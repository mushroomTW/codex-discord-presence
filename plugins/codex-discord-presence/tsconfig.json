  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": "scripts",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.ts", "scripts/**/*.js"]
}
