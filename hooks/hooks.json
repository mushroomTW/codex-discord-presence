{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/session-start.js\"",
            "timeout": 10,
            "statusMessage": "啟動 Discord Rich Presence"
          }
        ]
      }
    ]
  }
}
